<odoo>
    <record id="library_member_action" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="library_member_view_list" model="ir.ui.view">
        <field name="name">library.member.list</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="member_id"/>
                <field name="email"/>
                <field name="active_borrow_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="library_member_view_form" model="ir.ui.view">
        <field name="name">library.member.form</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button name="suspend_member" type="object" string="Suspend" invisible="state != 'active'"/>
                        <button name="activate_member" type="object" string="Activate" invisible="state != 'suspended'"/>
                        <field name="state" widget="statusbar" statusbar_visible="active,suspended"/>
                    </header>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <field name="member_id"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="active_borrow_count"/>
                    </group>
                    <notebook>
                        <page string="Borrow History">
                            <field name="borrow_record_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>