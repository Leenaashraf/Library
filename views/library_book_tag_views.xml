<odoo>
    <record id="library_book_tag_action" model="ir.actions.act_window">
        <field name="name">Book Tags</field>
        <field name="res_model">library.book.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="library_book_tag_view_list" model="ir.ui.view">
        <field name="name">library.book.tag.list</field>
        <field name="model">library.book.tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="library_book_tag_view_form" model="ir.ui.view">
        <field name="name">library.book.tag.form</field>
        <field name="model">library.book.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>