<odoo>
    <data>

        <record id="library_author_action" model="ir.actions.act_window">
            <field name="name">Authors</field>
            <field name="res_model">library.author</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="library_author_list_view" model="ir.ui.view">
            <field name="name">library.author.list</field>
            <field name="model">library.author</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="nationality"/>
                    <field name="email"/>
                </list>
            </field>
        </record>

        <record id="library_author_form_view" model="ir.ui.view">
            <field name="name">library.author.form</field>
            <field name="model">library.author</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="date_of_birth"/>
                            <field name="nationality"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>

                        <group>
                            <field name="biography"/>
                        </group>

                        <notebook>
                            <page string="Books">
                                <field name="book_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>