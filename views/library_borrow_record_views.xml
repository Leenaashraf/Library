<odoo>
    <record id="library_borrow_record_action" model="ir.actions.act_window">
        <field name="name">Borrow Records</field>
        <field name="res_model">library.borrow.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="library_borrow_record_view_list" model="ir.ui.view">
        <field name="name">library.borrow.record.list</field>
        <field name="model">library.borrow.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="book_id"/>
                <field name="member_id"/>
                <field name="borrow_date"/>
                <field name="due_date"/>
                <field name="return_date"/>
                <button name="return_book" type="object" string="Return" icon="fa-undo" invisible="state not in ('borrowed','overdue')"/>
                <button name="mark_lost" type="object" string="Mark Lost" icon="fa-exclamation-triangle" invisible="state not in ('borrowed','overdue')"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="library_borrow_record_view_form" model="ir.ui.view">
        <field name="name">library.borrow.record.form</field>
        <field name="model">library.borrow.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button name="return_book" type="object" string="Return Book" invisible="state not in ('borrowed','overdue')"/>
                        <button name="mark_lost" type="object" string="Mark Lost" invisible="state not in ('borrowed','overdue')"/>
                        <field name="state" widget="statusbar" statusbar_visible="borrowed,returned,overdue,lost"/>
                    </header>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <field name="book_id"/>
                        <field name="member_id"/>
                        <field name="borrow_date"/>
                        <field name="due_date"/>
                        <field name="return_date"/>
                        <field name="librarian_id"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>